generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// One row per agent your Hermes stack runs. Agents self-report here
/// via POST /api/agents/state. The dashboard reads from this table.
model AgentState {
  id             String    @id
  name           String
  emoji          String?
  role           String?
  group          String?   @default("default")
  status         String    @default("offline")
  lastActive     DateTime?
  tasksCompleted Int       @default(0)
  totalCost      Float     @default(0)
  currentTask    String?
  recentActivity Json?     @default("[]")
  updatedAt      DateTime  @updatedAt
  costBreakdowns CostBreakdown[]
}

/// Per-model cost + token attribution, one row per agent per model per window.
model CostBreakdown {
  id           String     @id @default(cuid())
  agentId      String
  agent        AgentState @relation(fields: [agentId], references: [id], onDelete: Cascade)
  model        String
  provider     String
  inputTokens  Int        @default(0)
  outputTokens Int        @default(0)
  cachedTokens Int        @default(0)
  costUsd      Decimal    @db.Decimal(12, 6)
  windowStart  DateTime
  windowEnd    DateTime
  createdAt    DateTime   @default(now())

  @@index([agentId, windowStart])
  @@index([model, windowStart])
  @@index([windowStart])
}

/// A unit of work assigned to an agent. Agents pick up pending missions,
/// run them, and update status to "completed" or "failed".
model Mission {
  id          String    @id @default(uuid())
  agentId     String
  title       String
  description String
  status      String    @default("pending")
  priority    String    @default("medium")
  result      String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([agentId])
  @@index([status])
}

/// Ideas your agents generate for you to review.
model Idea {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String?
  source      String?
  status      String?  @default("pending")
  timestamp   DateTime @default(now())

  @@index([category])
  @@index([status])
}

/// Generic key-value store for agent-specific config and scratch data.
model DataStore {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}
